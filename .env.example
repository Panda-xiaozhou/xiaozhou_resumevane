# ============================================================
# ResumeVane 环境变量配置模板
# ============================================================
# 使用方式:
#   cp .env.example .env
#   然后编辑 .env 填入真实值
#
# 注意: .env 包含敏感信息(API Key 等)，已加入 .gitignore，请勿提交到仓库
# ============================================================

# ── DeepSeek LLM API（必填）────────────────────────────
# 注册地址: https://platform.deepseek.com
# 获取 API Key: 登录后 → API Keys → 创建
# 模型可选: deepseek-chat(通用) / deepseek-reasoner(推理增强)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_MODEL 可选: deepseek-v4-flash(快思考，推荐) / deepseek-chat(通用)
DEEPSEEK_MODEL=deepseek-v4-flash

# ── BGE 向量化（第三方 API，用于简历语义检索）────────────
# BGE-M3 是智源开源的中文语义向量模型，通过硅基流动等第三方 API 调用
# 注册地址: https://siliconflow.cn（默认）或阿里云百炼、智谱等
# 如未单独申请，默认复用 DEEPSEEK_API_KEY
EMBEDDING_API_KEY=sk-your-embedding-api-key
# 第三方 API 地址（默认硅基流动，OpenAI 兼容接口）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# 模型名称（BGE-M3 多语言 1024 维）
EMBEDDING_MODEL=BAAI/bge-m3
# 语义技能命中阈值，余弦相似度 >= 此值视为命中
SEMANTIC_MATCH_THRESHOLD=0.7

# ── 飞书开放平台（可选—不填则跳过推送功能）────────────
# 创建飞书自建应用: https://open.feishu.cn → 开发者后台 → 创建企业自建应用
#   1. 获取 App ID 和 App Secret（凭证与基础信息页面）
#   2. 开启机器人能力（应用能力 → 机器人 → 启用）
#   3. 获取群聊 chat_id（飞书群 → 设置 → 群机器人 → 添加机器人 → 获取 chat_id）
#      chat_id 格式: oc_xxxxxxxxxxxxxxxx
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx
# 前端访问基址，用于飞书卡片“查看详情”按钮跳转
FRONTEND_BASE_URL=http://localhost:3000

# ── 数据库（本地开发默认值，Docker Compose 下无需修改）────
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 生产环境替换为云数据库地址
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumevane
